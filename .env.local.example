# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# LLM APIs
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
PERPLEXITY_API_KEY=

# Email (Resend)
RESEND_API_KEY=
# Remetente. Para enviar a clientes externos, o domínio tem de estar
# verificado no Resend. Ex.: "destaque.ai <contacto@destaque.ai>"
