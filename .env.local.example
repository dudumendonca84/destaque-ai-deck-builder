NEXT_PUBLIC_PROPOSAL_URL=https://destaque.ai

# Admin (único user permitido)
ADMIN_EMAIL=contacto@destaque.ai

# Cron (protege /api/cron/* — definido automaticamente pelo Vercel Cron)
CRON_SECRET=
